      <h1 className="text-3xl font-bold text-[#004080] mb-8 border-b-2 border-gray-200 pb-4 text-center">Struktur Organisasi</h1>
      
      <div className="flex justify-center mb-12">
        <img src="https://i.imgur.com/ofbSbWA.png" alt="Bagan Struktur Organisasi" className="max-w-full h-auto rounded shadow-lg border border-gray-200" />
      </div>

      <h2 className="text-2xl font-bold text-[#333333] mb-6 text-center">Daftar Pengurus Inti</h2>
      <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {db.struktur.map(item => (
          <div key={item.id} className="bg-white p-6 rounded-xl shadow-md border-t-4 border-[#004080] text-center">
            <div className="w-16 h-16 bg-blue-100 text-[#004080] rounded-full flex items-center justify-center mx-auto mb-4">
              <User size={32} />
            </div>
            <h3 className="text-sm text-gray-500 font-semibold uppercase tracking-wider mb-1">{item.jabatan}</h3>
            <p className="text-lg font-bold text-[#333333]">{item.nama}</p>
          </div>
        ))}
      </div>
    </div>
  );

  const PokjaPage = ({ id }) => {
    const data = db.pokja[id];
    if(!data) return null;

    return (
      <div className="max-w-4xl mx-auto px-4 py-12 relative animate-fade-in font-[Poppins]">
        <AdminEditOverlay onEdit={() => navigate('/admin')} />
        <h1 className="text-3xl font-bold text-[#004080] mb-8 border-b-2 border-gray-200 pb-4">{data.title}</h1>
        
        <div className="bg-white rounded-lg shadow-sm border border-gray-200 p-6 sm:p-8">
          <h2 className="text-xl font-semibold text-[#333333] mb-6 flex items-center gap-2">
            <FileText className="text-[#004080]"/> Program Kerja Utama
          </h2>
          <ul className="space-y-4">
            {data.items.map((item, idx) => (
              <li key={idx} className="flex items-start gap-3 text-[#333333] leading-relaxed">
                <div className="mt-1.5 w-2 h-2 rounded-full bg-[#004080] flex-shrink-0"></div>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    );
  };

  const BeritaList = () => (
    <div className="max-w-5xl mx-auto px-4 py-12 animate-fade-in font-[Poppins]">
      <div className="flex justify-between items-center mb-8 border-b-2 border-gray-200 pb-4">
        <h1 className="text-3xl font-bold text-[#004080]">Berita & Agenda</h1>
        {user?.role === 'admin' && (
          <button onClick={() => navigate('/admin')} className="bg-[#004080] text-white px-4 py-2 rounded flex items-center gap-2 text-sm hover:bg-blue-800">
            <Plus size={16}/> Tulis Berita
          </button>
        )}
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
        {db.berita.map(news => (
          <div key={news.id} className="bg-white rounded-lg shadow-md overflow-hidden border border-gray-100 hover:shadow-lg transition cursor-pointer flex flex-col" onClick={() => navigate(`/berita/${news.id}`)}>
            <img src={news.image} alt={news.title} className="w-full h-48 object-cover" />
            <div className="p-5 flex flex-col flex-grow">
              <p className="text-xs text-gray-500 mb-2">{news.date} | {news.author}</p>
              <h2 className="text-xl font-bold text-[#004080] mb-3 leading-tight">{news.title}</h2>
              <p className="text-[#333333] text-sm flex-grow mb-4">{news.excerpt}</p>
              <div className="text-blue-600 font-semibold text-sm flex items-center gap-1 mt-auto">Baca Selengkapnya <ArrowRight size={14}/></div>
            </div>
          </div>
        ))}
      </div>
      {/* Pagination Mock */}
      <div className="flex justify-center mt-10 gap-2">
        <button className="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300">Sebelumnya</button>
        <button className="px-4 py-2 bg-[#004080] text-white rounded">1</button>
        <button className="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300">Selanjutnya</button>
      </div>
    </div>
  );

  const BeritaDetail = ({ id }) => {
    const news = db.berita.find(b => b.id === parseInt(id));
    if(!news) return <div className="text-center py-20">Berita tidak ditemukan</div>;

    return (
      <div className="max-w-3xl mx-auto px-4 py-12 relative animate-fade-in font-[Poppins]">
        <AdminEditOverlay onEdit={() => navigate('/admin')} />
        <button onClick={() => navigate('/berita')} className="text-blue-600 mb-6 flex items-center gap-1 hover:underline">
          &larr; Kembali ke Daftar Berita
        </button>
        <h1 className="text-3xl md:text-4xl font-bold text-[#004080] mb-4 leading-tight">{news.title}</h1>
        <div className="flex items-center gap-4 text-sm text-gray-500 mb-8 border-b pb-4">
          <span>Ditulis oleh: {news.author}</span>
          <span>Dipublikasikan: {news.date}</span>
        </div>
        <img src={news.image} alt={news.title} className="w-full h-auto rounded-lg shadow-md mb-8" />
        <div className="prose max-w-none text-[#333333] leading-relaxed whitespace-pre-line text-lg">
          {news.content}
        </div>
      </div>
    );
  };

  const Galeri = () => (
    <div className="max-w-6xl mx-auto px-4 py-12 animate-fade-in font-[Poppins]">
      <div className="flex justify-between items-center mb-8 border-b-2 border-gray-200 pb-4">
        <h1 className="text-3xl font-bold text-[#004080]">Galeri Kegiatan</h1>
        {user?.role === 'admin' && (
          <button onClick={() => navigate('/admin')} className="bg-[#004080] text-white px-4 py-2 rounded flex items-center gap-2 text-sm hover:bg-blue-800">
            <Plus size={16}/> Upload Foto
          </button>
        )}
      </div>

      <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {db.galeri.map(foto => (
          <div key={foto.id} className="relative group rounded-lg overflow-hidden shadow-sm bg-black">
            <img src={foto.url} alt={foto.caption} className="w-full h-64 object-cover opacity-90 group-hover:opacity-50 transition duration-300" />
            <div className="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300 px-4 text-center">
              <span className="text-white font-semibold text-lg">{foto.caption}</span>
            </div>
            {user?.role === 'admin' && (
               <button className="absolute top-2 right-2 bg-red-500 text-white p-2 rounded-full opacity-0 group-hover:opacity-100 transition"><Trash2 size={16}/></button>
            )}
          </div>
        ))}
      </div>
    </div>
  );

  const Login = () => {
    const [u, setU] = useState('');
    const [p, setP] = useState('');

    return (
      <div className="min-h-[60vh] flex items-center justify-center bg-gray-50 px-4 animate-fade-in font-[Poppins]">
        <div className="max-w-md w-full bg-white rounded-xl shadow-lg p-8 border border-gray-100">
          <div className="text-center mb-8">
            <img src="https://i.imgur.com/RKo7mpg.jpeg" alt="Logo" className="h-16 mx-auto mb-4" />
            <h2 className="text-2xl font-bold text-[#004080]">Masuk ke Portal</h2>
            <p className="text-sm text-gray-500 mt-2">Gunakan kredensial Anda untuk mengakses sistem.</p>
          </div>
          <form onSubmit={(e) => { e.preventDefault(); handleLogin(u, p); }} className="space-y-5">
            <div>
              <label className="block text-sm font-medium text-[#333333] mb-1">Username</label>
              <input type="text" required value={u} onChange={(e) => setU(e.target.value)} className="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-[#004080] focus:border-[#004080] outline-none" placeholder="admin / anggota" />
            </div>
            <div>
              <label className="block text-sm font-medium text-[#333333] mb-1">Password</label>
              <input type="password" required value={p} onChange={(e) => setP(e.target.value)} className="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-[#004080] focus:border-[#004080] outline-none" placeholder="password" />
            </div>
            <button type="submit" className="w-full bg-[#004080] text-white py-2.5 rounded-md font-semibold hover:bg-blue-800 transition">
              Masuk
            </button>
          </form>
          <div className="mt-6 text-xs text-center text-gray-500 bg-gray-100 p-3 rounded">
            <strong>Demo Akun:</strong><br/>
            Admin: <code>admin</code> / <code>password</code><br/>
            Anggota: <code>anggota</code> / <code>password</code>
          </div>
        </div>
      </div>
    );
  };

  // --- ADMIN DASHBOARD COMPONENT ---
  const AdminDashboard = () => {
    const [activeTab, setActiveTab] = useState('berita');

    if (user?.role !== 'admin') {
      return (
        <div className="text-center py-20 text-red-600">
          <h2 className="text-2xl font-bold">Akses Ditolak</h2>
          <p>Anda tidak memiliki izin untuk melihat halaman ini.</p>
          <button onClick={() => navigate('/')} className="mt-4 underline text-[#004080]">Kembali ke Beranda</button>
        </div>
      );
    }

    return (
      <div className="flex flex-col md:flex-row min-h-screen bg-gray-100 font-[Poppins]">
        {/* Sidebar */}
        <div className="w-full md:w-64 bg-[#004080] text-white p-6 shadow-xl">
          <h2 className="text-xl font-bold mb-8 flex items-center gap-2 border-b border-blue-700 pb-4">
            <LayoutDashboard /> CMS Admin
          </h2>
          <ul className="space-y-2">
            {[
              { id: 'berita', icon: <FileText size={18}/>, label: 'Manajemen Berita' },
              { id: 'galeri', icon: <ImageIcon size={18}/>, label: 'Manajemen Galeri' },
              { id: 'struktur', icon: <Users size={18}/>, label: 'Struktur Organisasi' },
              { id: 'pokja', icon: <Settings size={18}/>, label: 'Konten Pokja' },
            ].map(tab => (
              <li key={tab.id}>
                <button 
                  onClick={() => setActiveTab(tab.id)}
                  className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg transition text-left ${activeTab === tab.id ? 'bg-white text-[#004080] font-semibold' : 'hover:bg-blue-800'}`}
                >
                  {tab.icon} {tab.label}
                </button>
              </li>
            ))}
          </ul>
          <button onClick={() => navigate('/')} className="w-full mt-10 flex items-center justify-center gap-2 px-4 py-2 border border-blue-400 rounded-lg hover:bg-blue-800 transition">
            Lihat Web Publik
          </button>
        </div>

        {/* Content Area */}
        <div className="flex-1 p-8 bg-gray-50 overflow-y-auto">
          <h1 className="text-2xl font-bold text-[#333333] mb-6 capitalize border-b pb-2">Manajemen {activeTab}</h1>
          
          <div className="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            {/* Tampilan Sederhana berdasarkan Tab (Mock CMS) */}
            
            {activeTab === 'berita' && (
              <div>
                <button className="bg-green-600 text-white px-4 py-2 rounded mb-6 flex items-center gap-2 hover:bg-green-700"><Plus size={16}/> Tulis Berita Baru</button>
                <div className="overflow-x-auto">
                  <table className="w-full text-left border-collapse">
                    <thead>
                      <tr className="bg-gray-100 text-gray-600 text-sm">
                        <th className="p-3">Judul</th>
                        <th className="p-3">Tanggal</th>
                        <th className="p-3">Aksi</th>
                      </tr>
                    </thead>
                    <tbody>
                      {db.berita.map(b => (
                        <tr key={b.id} className="border-b">
                          <td className="p-3 font-medium text-[#004080]">{b.title}</td>
                          <td className="p-3 text-sm text-gray-500">{b.date}</td>
                          <td className="p-3 flex gap-2">
                            <button className="p-1.5 bg-blue-100 text-blue-700 rounded hover:bg-blue-200" title="Edit"><Edit size={14}/></button>
                            <button className="p-1.5 bg-red-100 text-red-700 rounded hover:bg-red-200" title="Hapus"><Trash2 size={14}/></button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {activeTab === 'struktur' && (
               <div className="space-y-4">
                 <p className="text-sm text-gray-500 mb-4">*Ubah nama pengurus, biarkan kosong jika belum ada.</p>
                 {db.struktur.map((item, idx) => (
                   <div key={item.id} className="flex flex-col sm:flex-row gap-4 items-center bg-gray-50 p-3 rounded border">
                     <div className="w-full sm:w-1/3 font-semibold text-[#004080]">{item.jabatan}</div>
                     <input 
                        type="text" 
                        value={item.nama}
                        onChange={(e) => {
                          const newStruktur = [...db.struktur];
                          newStruktur[idx].nama = e.target.value;
                          setDb({...db, struktur: newStruktur});
                        }}
                        className="flex-1 p-2 border border-gray-300 rounded focus:ring-2 focus:ring-[#004080] outline-none w-full"
                     />
                   </div>
                 ))}
                 <button className="bg-[#004080] text-white px-6 py-2 rounded font-semibold mt-4">Simpan Perubahan</button>
               </div>
            )}

            {(activeTab === 'galeri' || activeTab === 'pokja') && (
              <div className="text-center py-10 text-gray-500">
                <ImageIcon size={48} className="mx-auto mb-4 opacity-50" />
                <p>Modul {activeTab} siap diintegrasikan dengan API Backend.</p>
                <p className="text-sm mt-2">Di aplikasi produksi, bagian ini menggunakan form upload (Sharp kompresi) dan Rich Text Editor (TipTap/React-Quill).</p>
              </div>
            )}

          </div>
        </div>
      </div>
    );
  };

  // --- ROUTER OUTLET ---
  const renderView = () => {
    if (currentPath.startsWith('/admin')) return <AdminDashboard />;
    if (currentPath === '/login') return <Login />;
    
    // Public Layout
    return (
      <div className="min-h-screen flex flex-col relative bg-white">
        <FloatingSocial />
        <TopBar />
        <Header />
        <main className="flex-grow">
          {currentPath === '/' && <Home />}
          {currentPath === '/profil/visi-misi' && <ProfilVisiMisi />}
          {currentPath === '/profil/tugas' && <ProfilTugas />}
          {currentPath === '/profil/struktur' && <ProfilStruktur />}
          {currentPath.startsWith('/pokja/') && <PokjaPage id={currentPath.split('/')[2]} />}
          {currentPath === '/berita' && <BeritaList />}
          {currentPath.startsWith('/berita/') && <BeritaDetail id={currentPath.split('/')[2]} />}
          {currentPath === '/galeri' && <Galeri />}
        </main>
        <Footer />
      </div>
    );
  };

  return renderView();
}
